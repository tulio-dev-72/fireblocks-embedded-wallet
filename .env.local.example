# Your Dynamic environment ID (Dashboard → Developers → SDK / API Keys).
# This is a PUBLIC, client-side identifier by design, safe to ship in the bundle.
# It is NOT an API secret. Do not put any Fireblocks/Dynamic *secret* keys in this app.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=replace-with-your-environment-id

# Optional: override the Amoy RPC. Defaults to the public Polygon Amoy RPC if unset.
NEXT_PUBLIC_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
